# Local-only config for scripts/audit_po_imports.py and related tooling.
# Copy this file to `.env` (same folder) and fill in the real values.
# `.env` is gitignored — never commit your credentials.

# Production API for the daily PO-import audit.
POAUDIT_API_BASE=https://hakimitraders.runasp.net

# A user with the `poformats.import.viewArchive` permission.
# For dev / staging you can use the seed admin (admin / admin123).
# For production, prefer a dedicated read-only operator account.
POAUDIT_USERNAME=admin
POAUDIT_PASSWORD=replace-me

# How many days back to scan in each run. 1 = "since this time yesterday".
POAUDIT_DAYS=1

# Server-side page size for archive listing. Max 200 (clamped server-side).
POAUDIT_PAGE_SIZE=200
