{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_LOCAL_SQL_SERVER;Database=YourDevDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "SeedAdminUserId": 1
  },
  "Pagination": {
    "DefaultPageSize": 10
  },
  "Gemini": {
    "ApiKey": "REPLACE_WITH_YOUR_GEMINI_API_KEY",
    "Model": "gemini-2.5-flash"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_AT_LEAST_32_CHAR_RANDOM_SECRET",
    "Issuer": "MyApp.Api",
    "Audience": "MyApp.Frontend",
    "ExpirationHours": 8
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173,http://localhost:5134"
  }
}
